# Copie ce fichier en ".env" (sans ".example") et remplis tes propres valeurs.
# Le fichier ".env" ne doit jamais être envoyé sur GitHub (il est déjà exclu
# dans .gitignore) : c'est là que vivent les mots de passe et clés secrètes.

# Clé secrète Django : génère la tienne, ne réutilise jamais celle d'un exemple.
# Tu peux en générer une nouvelle avec la commande (dans le terminal, dans le dossier du projet) :
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=remplace-moi-par-une-vraie-cle-secrete

# DEBUG=True affiche les erreurs détaillées (pratique en développement).
# Toujours DEBUG=False une fois le site en ligne pour de vrai (production) !
DEBUG=True

# Domaines/adresses autorisés à servir le site, séparés par des virgules.
# En local : 127.0.0.1,localhost
# Sur PythonAnywhere : tonpseudo.pythonanywhere.com
ALLOWED_HOSTS=127.0.0.1,localhost

# SQLite est la base par défaut (voir settings.py) : aucune des lignes
# ci-dessous n'est nécessaire tant que DB_ENGINE n'est pas "mysql".
# Elles ne servent que si MySQL redevient disponible (hébergement payant
# ou serveur avec MySQL 8+).
# DB_ENGINE=mysql
# DB_NAME=pharmguineefm
# DB_USER=root
# DB_PASSWORD=root
# DB_HOST=127.0.0.1
# DB_PORT=3306

# Envoi d'emails (notifications de suivi de commande aux patients).
# En local, laisse ces lignes vides ou absentes : les emails s'affichent
# juste dans le terminal (aucun envoi réel), pas besoin de vrais identifiants.
#
# En production, on utilise l'API Brevo (https://www.brevo.com, gratuit
# jusqu'à 300 emails/jour) plutôt que le SMTP Gmail : les comptes gratuits
# PythonAnywhere bloquent le SMTP de façon intermittente, mais les requêtes
# HTTPS classiques (comme l'API Brevo) fonctionnent toujours.
# BREVO_API_KEY=ta-cle-api-brevo
# BREVO_SENDER_EMAIL=l-adresse-que-tu-as-verifiee-sur-brevo@gmail.com
# DEFAULT_FROM_EMAIL=PharmaSila Guinée <l-adresse-que-tu-as-verifiee-sur-brevo@gmail.com>

# Ancienne méthode (SMTP Gmail) : gardée en repli pour le développement local
# uniquement, mais peu fiable sur PythonAnywhere gratuit en production.
# EMAIL_HOST_USER=pharmasila.notifications@gmail.com
# EMAIL_HOST_PASSWORD=le-mot-de-passe-d-application-a-16-caracteres
